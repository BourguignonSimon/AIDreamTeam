# ============================================================
# LangGraph Multi-Agent — Environment variables
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- LLM model names (LiteLLM model strings) ---
PM_MODEL=gpt-4o-mini
DEV_MODEL=gpt-4o-mini
QA_MODEL=gpt-4o-mini
ERROR_MODEL=gpt-4o-mini

# --- LiteLLM Proxy (optional — leave blank to call providers directly) ---
# LITELLM_PROXY_URL=http://localhost:4000
# LITELLM_API_KEY=your-proxy-key

# --- OpenAI (used when calling OpenAI models directly) ---
# OPENAI_API_KEY=sk-...

# --- Anthropic (for Claude models via LiteLLM) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Logging ---
LOG_LEVEL=INFO

# ── Redis Streams Worker ──────────────────────────────────────────────────────

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# Stream / consumer group names
REDIS_STREAM=audio-tasks
REDIS_DLQ_STREAM=audio-tasks:dlq
REDIS_CONSUMER_GROUP=audio-workers
# REDIS_CONSUMER_ID=audio-worker-myhost-1234   # auto-derived from hostname+pid if omitted

# Worker tuning
AUDIO_WORKER_MAX_RETRIES=3        # deliveries before a message is sent to DLQ
REDIS_BLOCK_MS=5000               # XREADGROUP blocking timeout in milliseconds
AUTOCLAIM_IDLE_MS=60000           # reclaim messages idle longer than this (ms)
AUTOCLAIM_INTERVAL_S=30           # how often to run XAUTOCLAIM (seconds)
RECONNECT_MAX_DELAY_S=60          # maximum back-off between Redis reconnect attempts

# ── Audio Transcription Service ──────────────────────────────────────────────

# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
# Recommended for RTX 3080 (10 GB VRAM): large-v2 for best accuracy/speed ratio
WHISPER_MODEL_SIZE=base

# Inference device: cuda | cpu | auto
WHISPER_DEVICE=cuda

# CTranslate2 compute type: float16 | int8_float16 | int8 (int8 = fastest on CPU)
WHISPER_COMPUTE_TYPE=float16
